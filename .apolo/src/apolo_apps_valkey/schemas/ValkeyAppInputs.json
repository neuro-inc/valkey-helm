      },
      "required": [
        "architecture_type"
      ],
      "title": "ValkeyStandaloneArchitecture",
      "type": "object",
      "x-description": "This mode will deploy a standalone\n                    Valkey StatefulSet. A single service will be exposed",
      "x-is-advanced-field": false,
      "x-is-configurable": true,
      "x-meta-type": "inline",
      "x-title": "Standalone Mode",
      "x-type": "ValkeyStandaloneArchitecture"
