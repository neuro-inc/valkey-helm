      "title": "WebhookConfig",
      "type": "object",
      "x-description": "Configure dedicated webhook processing instances. Separating webhook handling allows dedicated resource allocation for webhook traffic without competing with core workflow execution.",
      "x-is-advanced-field": false,
      "x-is-configurable": true,
      "x-meta-type": "inline",
      "x-title": "Webhook Configuration",
      "x-type": "WebhookConfig"
    },
    "WorkerConfig": {
      "properties": {
        "preset": {
          "$ref": "#/$defs/Preset"
        },
        "replicas": {
          "title": "Replicas",
