          ],
          "default": {
            "replicas": 1,
            "__type__": "ReplicaCount"
          },
          "title": "Replica Scaling",
          "x-description": "Choose a fixed number of replicas or enable autoscaling.",
          "x-is-advanced-field": false,
          "x-is-configurable": true,
          "x-meta-type": "inline",
          "x-title": "Replicas"
        },
        "persistence": {
          "anyOf": [
            {
              "$ref": "#/$defs/ValkeyVolume"
            },
            {
              "type": "null"
            }
          ],
          "default": {
            "storage_mount": {
              "__type__": "ApoloFilesPath",
              "path": "storage:.apps/valkey/valkey-app"
            },
            "__type__": "ValkeyVolume"
          }
        }
      },
      "required": [
        "preset"
      ],
      "title": "MainApplicationConfig",
      "type": "object",
      "x-description": "Configure the primary Valkey service that handles core data storage functionality, processes requests, and manages the core infrastructure.",
      "x-is-advanced-field": false,
      "x-is-configurable": true,
      "x-meta-type": "inline",
      "x-title": "Main Application Configuration",
      "x-type": "MainApplicationConfig"
