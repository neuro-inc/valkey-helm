    "ReplicaCount": {
      "properties": {
        "replicas": {
          "default": 1,
          "title": "Replicas",
          "type": "integer",
          "x-description": "Number of replicas created for main application.",
          "x-is-advanced-field": false,
          "x-is-configurable": true,
          "x-meta-type": "inline",
          "x-title": "Replica Count"
        }
      },
      "title": "ReplicaCount",
      "type": "object",
      "x-description": "This option creates a fixed number of replicas with no autoscaling enabled.",
      "x-is-advanced-field": false,
      "x-is-configurable": true,
      "x-meta-type": "inline",
      "x-title": "Fixed Replica Count",
      "x-type": "ReplicaCount"
