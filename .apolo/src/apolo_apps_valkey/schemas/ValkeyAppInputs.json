          "default": null,
          "x-description": "Enable Autoscaling and configure it.",
          "x-is-advanced-field": true,
          "x-is-configurable": true,
          "x-meta-type": "inline",
          "x-title": "Autoscaling"
        }
      },
      "required": [
        "architecture_type",
        "replica_preset"
