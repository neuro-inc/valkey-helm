          "x-description": "Select a platform storage path to mount for the Valkey data directory. This is required to persist critical data.",
          "x-title": "Storage Mount Path"
        }
      },
      "title": "ValkeyVolume",
      "type": "object",
      "x-description": "Configure persistent storage for the Valkey data directory. This volume stores encryption keys, instance logs, and source control assets. Persistence is recommended for production deployments.",
      "x-is-advanced-field": false,
      "x-is-configurable": true,
      "x-meta-type": "inline",
      "x-title": "Persistent Storage",
      "x-type": "ValkeyVolume"
