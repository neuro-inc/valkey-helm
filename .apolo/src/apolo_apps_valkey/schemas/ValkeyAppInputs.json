      "title": "AutoscalingHPA",
      "type": "object",
      "x-description": "Autoscaling configuration for Horizontal Pod Autoscaler.",
      "x-is-advanced-field": false,
      "x-is-configurable": true,
      "x-meta-type": "inline",
      "x-title": "Autoscaling HPA",
      "x-type": "AutoscalingHPA"
