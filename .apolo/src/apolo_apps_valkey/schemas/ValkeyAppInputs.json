      "title": "ValkeyReplicationArchitecture",
      "type": "object",
      "x-description": "This mode will deploy a Valkey\n                    primary StatefulSet and a Valkey replicas StatefulSet.\n                    The replicas will be read-replicas of the primary and\n                    two services will be exposed",
      "x-is-advanced-field": false,
      "x-is-configurable": true,
      "x-meta-type": "inline",
      "x-title": "Replication Mode",
      "x-type": "ValkeyReplicationArchitecture"
    },
    "ValkeyStandaloneArchitecture": {
      "properties": {
        "architecture_type": {
          "const": "standalone",
          "title": "Architecture Type",
          "type": "string"
