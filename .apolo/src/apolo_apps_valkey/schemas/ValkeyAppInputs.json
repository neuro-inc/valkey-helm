      "required": [
        "preset",
        "replicas"
      ],
      "title": "WorkerConfig",
      "type": "object",
      "x-description": "Configure workers for distributed background job processing. Workers handle workflow execution tasks, enabling the main application to remain responsive by offloading computational work.",
      "x-is-advanced-field": false,
      "x-is-configurable": true,
      "x-meta-type": "inline",
      "x-title": "Worker Configuration",
      "x-type": "WorkerConfig"
