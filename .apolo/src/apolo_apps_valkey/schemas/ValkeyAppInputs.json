  "properties": {
    "main_app_config": {
      "$ref": "#/$defs/MainApplicationConfig"
    },
    "worker_config": {
      "$ref": "#/$defs/WorkerConfig"
    },
    "webhook_config": {
      "$ref": "#/$defs/WebhookConfig"
    },
    "valkey_config": {
      "$ref": "#/$defs/ValkeyConfig"
    },
    "networking": {
      "$ref": "#/$defs/BasicNetworkingConfig",
      "x-description": "Configure network access, HTTP authentication, and related connectivity options."
    }
  },
  "required": [
    "main_app_config",
    "worker_config",
    "webhook_config",
    "valkey_config"
